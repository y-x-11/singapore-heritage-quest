# After deploying the teacher dashboard to GitHub Pages, set your live URL:
EXPO_PUBLIC_DASHBOARD_URL=https://YOUR_GITHUB_USERNAME.github.io/singapore-heritage-quest/

# Firebase (optional — demo mode works without these)
EXPO_PUBLIC_FIREBASE_API_KEY=your-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=heritage-quest-ar
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=your-app-id
